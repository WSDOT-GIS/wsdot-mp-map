              }
            ],
            "title": ""
          }
        ],
        "expressionInfos": [
          {
            "name": "expr0",
            "title": "SRMP",
            "expression": "// Concatenates label for SRMP value\n\nConcatenate(Round($feature.Srmp, 3) + $feature.Back)\n",
            "returnType": "string"
          },
          {
            "name": "expr1",
            "title": "City",
            "expression": "var cityFeature = First(Within(FeatureSetByName($map, \"City Limits\", ['CityName', 'LastUpdate']), $userInput))\n\nif (cityFeature == null) {\n  return \"Not within a city\"\n}\n\nvar city = cityFeature[\"CityName\"]\nvar lastUpdate = DateOnly(cityFeature[\"LastUpdate\"])\n\nif (lastUpdate == null) {\n  city\n} else {\n  return city + \" (Last updated \" + lastUpdate + \")\"\n}\n",
            "returnType": "string"
          },
          {
            "name": "expr2",
            "title": "Route at SRMP Label",
            "expression": "$feature.Route +  \" @ \" + Round($feature.Srmp, 3) + DefaultValue($feature.Back, \"\")",
            "returnType": "string"
          },
          {
            "name": "expr3",
            "title": "County",
            "expression": "var fs = FeatureSetByName($map, \"Counties\", [\"JURLBL\"])\nFirst(Within(fs, $userInput)).JURLBL",
            "returnType": "string"
          },
          {
            "name": "expr4",
            "title": "Access Control",
            "expression": "/**\n * Returns the Access Control type of the current feature\n */\n\n// Specify which fields you want to return.\n// Order of field names DOES NOT determine order\n// of fields in returned feature set.\nvar fields = [\n  \"AccessControlTypeDescription\",\n];\nvar fs = FeatureSetByName($map, \"Access Control\", fields);\nvar currentGeometry = Geometry($feature);\nvar bufferedGeometry = BufferGeodetic(currentGeometry, 4, \"feet\");\nvar intersectingFeatures = First(Distinct(Intersects(fs, bufferedGeometry), fields))[fields[0]];\n\nintersectingFeatures",
            "returnType": "string"
          },
          {
            "name": "expr5",
            "title": "Township Subdivision",
            "expression": "var featureSetName = \"Township Subdivision\";\nvar fieldName = \"LEGAL_DESC_NM\"\nvar fs = FeatureSetByName($map, featureSetName, [fieldName]);\nvar filteredFS = Within(fs, $feature);\nreturn First(filteredFS)[fieldName];",
            "returnType": "string"
          }
        ],
